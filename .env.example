# ============================================================
#  Multimodal RAG 项目环境变量配置
#  复制本文件为 .env 并填入你的真实密钥
# ============================================================

# ──────────────── LLM / Embedding API 密钥 ────────────────

# 智谱 GLM
GLM_API_KEY=your_glm_api_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# 硅基流动 SiliconFlow（用于 Embedding 和 rag_eval 评测 LLM）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# 阿里巴巴 通义（用于网络搜索）
ALIBABA_API_KEY=your_alibaba_api_key_here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Moonshot Kimi
K2_API_KEY=your_k2_api_key_here
K2_BASE_URL=https://api.moonshot.cn/v1

# MiMo（主多模态 LLM）
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.siliconflow.cn/v1

# ──────────────── 本地私有化部署 ────────────────

LOCAL_BASE_URL=http://localhost:8000/v1

# ──────────────── Milvus 向量数据库 ────────────────

MILVUS_URI=http://localhost:19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# ──────────────── Redis（短期会话状态）────────────────

REDIS_URL=redis://localhost:6379
